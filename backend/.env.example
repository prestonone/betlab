###############################################################################
# BET LAB BACKEND ENVIRONMENT TEMPLATE
###############################################################################

# -----------------------------------------------------------------------------
# DJANGO
# -----------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=replace-with-your-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://username:password@localhost:5432/betlab

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
ACCESS_TOKEN_LIFETIME=15
REFRESH_TOKEN_LIFETIME=7

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# PAYSTACK
# -----------------------------------------------------------------------------
# PAYSTACK_MODE selects which key pair below is actually used ("test" or "live").
PAYSTACK_MODE=test
PAYSTACK_TEST_PUBLIC_KEY=
PAYSTACK_TEST_SECRET_KEY=
PAYSTACK_LIVE_PUBLIC_KEY=
PAYSTACK_LIVE_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=http://localhost:5173/dashboard?payment=callback

# -----------------------------------------------------------------------------
# EMAIL (RESEND) — required for account verification and password reset
# -----------------------------------------------------------------------------
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=noreply@betlabhq.com

# -----------------------------------------------------------------------------
# NOT YET IMPLEMENTED — no code reads these; reserved for future features
# -----------------------------------------------------------------------------
TERMII_API_KEY=
TERMII_SENDER_ID=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REDIS_URL=
CELERY_BROKER_URL=
SENTRY_DSN=
OPENAI_API_KEY=
